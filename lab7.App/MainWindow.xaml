<Window x:Class="lab7.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лаба 7. Каравашкин Клим 4233" Height="600" Width="900" Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Text="X:"/>
            <TextBox x:Name="TxtX" Margin="0,0,0,5" Text="50"/>
            <TextBlock Text="Y:"/>
            <TextBox x:Name="TxtY" Margin="0,0,0,5" Text="50"/>
            <TextBlock Text="Ширина/Радиус:"/>
            <TextBox x:Name="TxtSize" Margin="0,0,0,5" Text="100"/>
            <TextBlock Text="Высота:"/>
            <TextBox x:Name="TxtHeight" Margin="0,0,0,10" Text="100"/>

            <Button Content="Прямоугольник" Click="BtnAddRectangle_Click" Margin="0,0,0,3"/>
            <Button Content="Квадрат" Click="BtnAddSquare_Click" Margin="0,0,0,3"/>
            <Button Content="Эллипс" Click="BtnAddEllipse_Click" Margin="0,0,0,3"/>
            <Button Content="Окружность" Click="BtnAddCircle_Click" Margin="0,0,0,10"/>

            <ListBox x:Name="LstFigures" Height="100" Margin="0,0,0,5"/>
            <Button Content="Удалить" Click="BtnDelete_Click" Margin="0,0,0,5" Background="#FFDDA0A0"/>

            <TextBox x:Name="TxtNewRadius" Margin="0,0,0,3" Text="Новый радиус"/>

            <Button Content="Изменить радиус круга" Click="BtnChangeRadius_Click" Margin="0,0,0,10"/>
            <Button Content="Очистить всё" Click="BtnClearAll_Click" Margin="0,0,0,5"/>
            <Button Content="Инструкция!!!" Click="BtnHelp_Click" Background="#FFA0DDA0"/>
        </StackPanel>

        <Border Grid.Column="1" Margin="10" BorderBrush="Gray" BorderThickness="1">
            <Image x:Name="DrawingImage" Stretch="Uniform"/>
        </Border>
    </Grid>
</Window>